		{
			"name": "🔐 Authentication",
			"description": "Customer authentication via Firebase. Base: /api/v1/customer/auth",
			"item": [
				{
					"name": "Firebase Verify (Login/Register)",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firebaseIdToken\": \"<your_firebase_id_token>\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/customer/auth/firebase-verify",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "customer", "auth", "firebase-verify"]
						},
						"description": "Verify Firebase ID token and login or register a customer. Returns JWT token for subsequent requests."
					},
					"response": []
				},
