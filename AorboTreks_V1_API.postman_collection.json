						"body": {
							"mode": "raw",
							"raw": "{\n    \"batch_id\": 1,\n    \"traveler_count\": 2,\n    \"coupon_code\": \"\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/bookings/calculate-fare",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "bookings", "calculate-fare"]
						},
						"description": "Step 1: Server-side fare calculation. Returns fare_token, breakdown, and expires_at."
					},
					"response": []
				},
				{
					"name": "Step 2 — Create Order",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"fare_token\": \"<fare_token_from_step_1>\",\n    \"travelers\": [\n        {\n            \"name\": \"John Doe\",\n            \"age\": 28,\n            \"gender\": \"male\"\n        }\n    ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/bookings/create-order",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "bookings", "create-order"]
						},
						"description": "Step 2: Create Razorpay order. Returns order_id, amount, and razorpay_key."
					},
					"response": []
				},
				{
					"name": "Step 3 — Verify Payment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"merchant_order_id\": \"<merchant_order_id_from_step_2>\"\n}"
